# ============================================================
# Automatejobs.ia — Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# Backend Database
# SQLite is used by default (no setup required for development)
# For production, use PostgreSQL:
MONGO_URL=
DB_NAME=automatejobs

# CORS — Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000,http://localhost

# Frontend — Backend API URL (build-time variable for React)
REACT_APP_BACKEND_URL=http://localhost:8001

# Optional: AI Provider Keys (for AI Chat feature)
# If not set, the AI assistant uses deterministic data-driven responses
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
